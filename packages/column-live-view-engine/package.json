{
  "name": "@view-server/column-live-view-engine",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "bench:raw-live-fanout": "sh -c 'output=.artifacts/raw-live-fanout-${VIEW_SERVER_ENGINE_BENCH_FANOUT_CASE:-same-window}-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows-${VIEW_SERVER_ENGINE_BENCH_SUBSCRIBERS:-50}subs.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-live-fanout.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-live-fanout:same-window": "sh -c 'output=.artifacts/raw-live-fanout-same-window-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows-${VIEW_SERVER_ENGINE_BENCH_SUBSCRIBERS:-50}subs.json; VIEW_SERVER_ENGINE_BENCH_FANOUT_CASE=same-window VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-live-fanout.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-live-fanout:ten-window": "sh -c 'output=.artifacts/raw-live-fanout-ten-window-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows-${VIEW_SERVER_ENGINE_BENCH_SUBSCRIBERS:-50}subs.json; VIEW_SERVER_ENGINE_BENCH_FANOUT_CASE=ten-window VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-live-fanout.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:grouped-aggregate": "sh -c 'output=.artifacts/grouped-aggregate-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/grouped-aggregate.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:grouped-key-width": "sh -c 'output=.artifacts/grouped-key-width-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/grouped-key-width.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:grouped-write": "sh -c 'suffix=${VIEW_SERVER_ENGINE_BENCH_ARTIFACT_SUFFIX:-}; readerProfile=${VIEW_SERVER_ENGINE_BENCH_GROUPED_WRITE_READER_PROFILE:-dual}; readerProfileSegment=; if [ \"$readerProfile\" != dual ]; then readerProfileSegment=-$readerProfile; fi; output=.artifacts/grouped-write-${VIEW_SERVER_ENGINE_BENCH_GROUPED_WRITE_MODE:-incremental}${readerProfileSegment}-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows-${VIEW_SERVER_ENGINE_BENCH_WRITE_BATCH_SIZE:-1}mutations${suffix:+-$suffix}.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/grouped-write.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta": "sh -c 'output=.artifacts/raw-active-retained-delta-${VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE:-visible-delete}-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:count-only": "sh -c 'output=.artifacts/raw-active-retained-delta-count-only-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=count-only VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:exhausted-lookahead": "sh -c 'output=.artifacts/raw-active-retained-delta-exhausted-lookahead-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=exhausted-lookahead VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:match-move-up": "sh -c 'output=.artifacts/raw-active-retained-delta-match-move-up-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=match-move-up VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:match-update": "sh -c 'output=.artifacts/raw-active-retained-delta-match-update-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=match-update VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:noop": "sh -c 'output=.artifacts/raw-active-retained-delta-noop-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=noop VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:predicate-enter": "sh -c 'output=.artifacts/raw-active-retained-delta-predicate-enter-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=predicate-enter VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-active-retained-delta:visible-delete": "sh -c 'output=.artifacts/raw-active-retained-delta-visible-delete-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_RETAINED_CASE=visible-delete VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-active-retained-delta.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-predicate-index": "sh -c 'output=.artifacts/raw-predicate-index-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-predicate-index.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-snapshot": "sh -c 'output=.artifacts/raw-snapshot-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-snapshot.bench.ts --run --testTimeout 0 --outputJson $output'",
    "bench:raw-write": "sh -c 'output=.artifacts/raw-write-${VIEW_SERVER_ENGINE_BENCH_WRITE_MODE:-indexed}-${VIEW_SERVER_ENGINE_BENCH_ROWS:-100000}rows.json; VIEW_SERVER_ENGINE_BENCH_OUTPUT_JSON=$output vp test bench src/raw-write.bench.ts --run --testTimeout 0 --outputJson $output'",
    "test": "vp test run --coverage --typecheck"
  },
  "dependencies": {
    "@view-server/config": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "@vitest/runner": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
